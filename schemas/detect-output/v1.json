{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-delivery-spec.dev/schemas/detect-output/v1.json",
  "title": "ODS Detect Output v1",
  "description": "Output of `ods detect --json`: the result of AI code detection across commit trailers, branch names, PR descriptions, and diff heuristics.",
  "type": "object",
  "required": ["ai_generated", "confidence", "evidence", "sources", "summary"],
  "properties": {
    "ai_generated": {
      "type": "boolean",
      "description": "Whether AI-generated code was detected (confidence >= 0.3)."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Aggregate detection confidence (0.0–1.0): the highest individual signal plus a small boost per corroborating signal."
    },
    "files": {
      "type": "array",
      "description": "Per-file detection results from diff heuristics. Omitted when no files were fingerprinted.",
      "items": { "$ref": "#/$defs/FileDetection" }
    },
    "evidence": {
      "type": "array",
      "description": "Individual signals that contributed to the verdict.",
      "items": { "$ref": "#/$defs/Evidence" }
    },
    "sources": {
      "type": "array",
      "description": "Names of the signal sources that fired (e.g. commit-trailer, branch-name, pr-body, diff-heuristics).",
      "items": { "type": "string" }
    },
    "summary": {
      "type": "string",
      "description": "Human-readable one-line verdict."
    }
  },
  "$defs": {
    "FileDetection": {
      "type": "object",
      "required": ["path", "ai_lines", "total_lines", "confidence"],
      "properties": {
        "path": { "type": "string", "description": "Repository-relative file path." },
        "ai_lines": { "type": "integer", "minimum": 0, "description": "Estimated AI-generated lines." },
        "total_lines": { "type": "integer", "minimum": 0, "description": "Total lines considered in the file." },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Per-file detection confidence." }
      }
    },
    "Evidence": {
      "type": "object",
      "required": ["source", "confidence"],
      "properties": {
        "source": { "type": "string", "description": "Signal source (e.g. commit-trailer, branch-name)." },
        "signal": { "type": "string", "description": "Machine-readable signal identifier." },
        "value": { "type": "string", "description": "Human-readable description of the matched signal." },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "Confidence contributed by this signal." }
      }
    }
  }
}
